<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">
  <div class="card p-4 shadow-sm" style="min-width:340px; max-width:400px; width:100%; border-radius:14px;">
    <h2 class="mb-4 text-center" style="color:#059669;">Kayıt Ol</h2>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="mb-3">
        <%= f.label :email, 'E-posta', class: 'form-label' %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: 'form-control' %>
      </div>
      <div class="mb-3">
        <%= f.label :password, 'Şifre', class: 'form-label' %>
        <%= f.password_field :password, autocomplete: "new-password", class: 'form-control' %>
      </div>
      <div class="mb-3">
        <%= f.label :password_confirmation, 'Şifre (Tekrar)', class: 'form-label' %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: 'form-control' %>
      </div>
      <div class="d-grid gap-2 mb-2">
        <%= f.submit "Kayıt Ol", class: "btn btn-success" %>
      </div>
    <% end %>
    <div class="text-center mt-2">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
