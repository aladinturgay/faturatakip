
<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">
  <div class="card p-4 shadow-sm" style="min-width:340px; max-width:420px; width:100%; border-radius:14px;">
    <h2 class="mb-3 text-center" style="color:#2563eb;">Abonelik Detayı</h2>
    <div class="mb-3">
      <p><strong>Ad:</strong> <%= @subscription.name %></p>
      <p><strong>Durum:</strong>
        <% if @subscription.status == 'active' %>
          <span class="badge bg-success">Aktif</span>
        <% elsif @subscription.status == 'inactive' %>
          <span class="badge bg-secondary">Pasif</span>
        <% else %>
          <span class="badge bg-secondary">Bilinmiyor</span>
        <% end %>
      </p>
      <p><strong>Başlangıç:</strong> <%= @subscription.start_date %></p>
      <p><strong>Bitiş:</strong> <%= @subscription.end_date %></p>
    </div>
    <div class="d-grid gap-2 mb-2">
      <% if user_signed_in? && @subscription.user == current_user %>
        <%= link_to 'Düzenle', edit_subscription_path(@subscription), class: 'btn btn-warning' %>
      <% end %>
      <%= link_to 'Faturaları Gör', invoices_path(subscription_id: @subscription.id), class: 'btn btn-primary' %>
      <%= link_to 'Yeni Fatura Ekle', new_invoice_path(subscription_id: @subscription.id), class: 'btn btn-success' %>
    </div>
    <div class="text-center mt-2">
      <%= link_to 'Tüm Abonelikler', subscriptions_path, class: 'btn btn-secondary btn-sm me-2' %>
      <%= link_to 'Ana Sayfa', root_path, class: 'btn btn-secondary btn-sm' %>
    </div>
  </div>
</div>
