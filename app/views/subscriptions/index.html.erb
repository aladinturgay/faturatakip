<h2 class="mb-3 text-center" style="color:#2563eb;">Abonelikler</h2>
<div class="card p-3 mb-4 table-responsive" style="max-width:900px; margin:auto;">
<table class="table table-striped table-bordered align-middle mb-0" style="background:#fff; border-radius:8px; overflow:hidden; min-width:600px;">
  <thead class="table-light">
    <tr>
      <th>Ad</th>
      <th>Durum</th>
      <th>Başlangıç</th>
      <th>Bitiş</th>
      <th>Detay</th>
      <th>Sil</th>
    </tr>
  </thead>
  <tbody>
    <% @subscriptions.each do |sub| %>
      <tr>
        <td data-label="Ad"><%= sub.name %></td>
        <td data-label="Durum">
          <% if sub.status == 'active' %>
            <span class="badge bg-success">Aktif</span>
          <% elsif sub.status == 'inactive' %>
            <span class="badge bg-secondary">Pasif</span>
          <% else %>
            <span class="badge bg-secondary">Bilinmiyor</span>
          <% end %>
        </td>
        <td data-label="Başlangıç"><%= sub.start_date %></td>
        <td data-label="Bitiş"><%= sub.end_date %></td>
        <td data-label="Detay"><%= link_to raw('<i class="fas fa-eye"></i> Detay'), subscription_path(sub), class: 'btn btn-sm btn-outline-primary' %></td>
        <td data-label="Sil">
          <%= button_to 'Sil', subscription_path(sub), method: :delete, data: { confirm: 'Aboneliği silmek istediğinize emin misiniz?' }, class: 'btn btn-sm btn-outline-danger' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
</div>
<div class="text-center">
  <%= link_to 'Yeni Abonelik', new_subscription_path, class: 'btn btn-success me-2' %>
  <%= link_to 'Ana Sayfa', root_path, class: 'btn btn-secondary' %>
</div>
