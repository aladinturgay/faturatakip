		<div class="text-center mt-2">
			<button type="button" class="btn btn-outline-dark btn-sm" onclick="window.history.back()">Geri Dön</button>
		</div>
<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">
	<div class="card p-4 shadow-sm" style="min-width:340px; max-width:420px; width:100%; border-radius:14px;">
		<h2 class="mb-4 text-center" style="color:#2563eb;">Abonelik Düzenle</h2>
		<% if @subscription.errors.any? %>
			<div class="alert alert-danger">
				<ul class="mb-0">
					<% @subscription.errors.full_messages.each do |msg| %>
						<li><%= msg %></li>
					<% end %>
				</ul>
			</div>
		<% end %>
		<%= form_with(model: @subscription, local: true) do |f| %>
			<div class="mb-3">
				<%= f.label :name, 'Abonelik Adı', class: 'form-label' %>
				<%= f.text_field :name, class: 'form-control' %>
			</div>
			<div class="mb-3">
				<%= f.label :status, 'Durum', class: 'form-label' %>
				<%= f.select :status, [['Aktif', 'active'], ['Pasif', 'inactive']], {}, {class: 'form-select'} %>
			</div>
			<div class="mb-3">
				<%= f.label :start_date, 'Başlangıç Tarihi', class: 'form-label' %>
				<%= f.date_field :start_date, class: 'form-control' %>
			</div>
			<div class="mb-3">
				<%= f.label :end_date, 'Bitiş Tarihi', class: 'form-label' %>
				<%= f.date_field :end_date, class: 'form-control' %>
			</div>
			<div class="d-grid gap-2 mb-2">
				<%= f.submit "Güncelle", class: "btn btn-success" %>
			</div>
		<% end %>
		<div class="text-center mt-2">
			<%= link_to 'Abonelik Detayına Dön', subscription_path(@subscription), class: 'btn btn-secondary btn-sm me-2' %>
			<%= link_to 'Ana Sayfa', root_path, class: 'btn btn-secondary btn-sm' %>
		</div>
	</div>
</div>
