<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">
  <div class="card p-4 shadow-sm" style="min-width:340px; max-width:420px; width:100%; border-radius:14px;">
    <h2 class="mb-4 text-center" style="color:#f59e42;">Fatura Detayı</h2>
    <dl class="row mb-3">
      <dt class="col-5">Abonelik:</dt>
      <dd class="col-7"><%= @invoice.subscription.name if @invoice.subscription %></dd>
      <dt class="col-5">Tutar:</dt>
      <dd class="col-7"><%= number_to_currency(@invoice.amount, unit: '₺', separator: ',', delimiter: '.') %></dd>
      <dt class="col-5">Durum:</dt>
      <dd class="col-7">
        <% if @invoice.status == 'paid' %>
          <span class="badge bg-success">Ödendi</span>
        <% elsif @invoice.status == 'unpaid' %>
          <span class="badge bg-danger">Ödenmedi</span>
        <% else %>
          <span class="badge bg-secondary">Bilinmiyor</span>
        <% end %>
      </dd>
      <dt class="col-5">Düzenlenme Tarihi:</dt>
      <dd class="col-7"><%= @invoice.issued_at %></dd>
      <dt class="col-5">Son Ödeme Tarihi:</dt>
      <dd class="col-7"><%= @invoice.due_at %></dd>
    </dl>
    <div class="d-grid gap-2 mb-2">
      <% if user_signed_in? && @invoice.user == current_user %>
        <%= link_to 'Düzenle', edit_invoice_path(@invoice), class: 'btn btn-warning' %>
      <% end %>
    </div>
    <div class="text-center mt-2">
      <%= link_to 'Tüm Faturalar', invoices_path, class: 'btn btn-secondary btn-sm me-2' %>
      <%= link_to 'Ana Sayfa', root_path, class: 'btn btn-secondary btn-sm' %>
    </div>
  </div>
</div>

