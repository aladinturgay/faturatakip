
<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">
	<div class="card p-4 shadow-sm" style="min-width:340px; max-width:420px; width:100%; border-radius:14px;">
		<h2 class="mb-4 text-center" style="color:#f59e42;">Fatura Düzenle</h2>
		<% if @invoice.errors.any? %>
			<div class="alert alert-danger">
				<ul class="mb-0">
					<% @invoice.errors.full_messages.each do |msg| %>
						<li><%= msg %></li>
					<% end %>
				</ul>
			</div>
		<% end %>
		<%= form_with(model: @invoice, local: true) do |f| %>
			<div class="mb-3">
				<%= f.label :subscription_id, 'Abonelik', class: 'form-label' %>
				<%= f.collection_select :subscription_id, current_user.subscriptions, :id, :name, {prompt: 'Seçiniz'}, {class: 'form-select'} %>
			</div>
			<div class="mb-3">
				<%= f.label :amount, 'Tutar', class: 'form-label' %>
				<%= f.number_field :amount, step: 0.01, class: 'form-control' %>
			</div>
			<div class="mb-3">
				<%= f.label :status, 'Durum', class: 'form-label' %>
				<%= f.select :status, [['Ödendi', 'paid'], ['Ödenmedi', 'unpaid']], {}, {class: 'form-select'} %>
			</div>
			<div class="mb-3">
				<%= f.label :issued_at, 'Düzenlenme Tarihi', class: 'form-label' %>
				<%= f.date_field :issued_at, class: 'form-control' %>
			</div>
			<div class="mb-3">
				<%= f.label :due_at, 'Son Ödeme Tarihi', class: 'form-label' %>
				<%= f.date_field :due_at, class: 'form-control' %>
			</div>
			<div class="d-grid gap-2 mb-2">
				<%= f.submit "Güncelle", class: "btn btn-success" %>
			</div>
		<% end %>
		<div class="text-center mt-2">
			<%= link_to 'Fatura Detayına Dön', invoice_path(@invoice), class: 'btn btn-secondary btn-sm me-2' %>
			<%= link_to 'Ana Sayfa', root_path, class: 'btn btn-secondary btn-sm' %>
		</div>
	</div>
</div>
