
<div class="d-flex align-items-start flex-wrap flex-md-nowrap" style="min-height: 100vh;">
  <nav class="bg-dark text-white p-4" style="width: 220px; min-width:180px; min-height: 100vh;" id="sideMenu">
    <div class="mb-4 text-center">
      <i class="fas fa-network-wired fa-2x mb-2"></i>
      <h4 style="font-weight:bold;">Takip Paneli</h4>
    </div>
    <ul class="nav flex-column">
      <li class="nav-item mb-2"><%= link_to raw('<i class="fas fa-layer-group"></i> Abonelikler'), subscriptions_path, class: 'nav-link text-white' %></li>
      <li class="nav-item mb-2"><%= link_to raw('<i class="fas fa-file-invoice"></i> Faturalar'), invoices_path, class: 'nav-link text-white' %></li>
      <% if user_signed_in? %>
        <li class="nav-item mt-4"><%= link_to raw('<i class="fas fa-sign-out-alt"></i> Çıkış Yap'), destroy_user_session_path, method: :delete, class: 'nav-link text-danger' %></li>
      <% else %>
        <li class="nav-item mt-4"><%= link_to raw('<i class="fas fa-sign-in-alt"></i> Giriş Yap'), new_user_session_path, class: 'nav-link text-success' %></li>
        <li class="nav-item"><%= link_to raw('<i class="fas fa-user-plus"></i> Kayıt Ol'), new_user_registration_path, class: 'nav-link text-success' %></li>
      <% end %>
    </ul>
  </nav>
  <main class="flex-grow-1 p-4" style="min-width:0;">
    <h1 class="mb-4 text-center" style="color:#1976d2;">Fatura Takip Sistemi</h1>
    <% if user_signed_in? %>
      <div class="d-flex flex-wrap justify-content-center mb-4 gap-3 gap-md-4" style="width:100%;margin:0 auto;">
        <%= link_to subscriptions_path, style: 'text-decoration:none;' do %>
          <div class="card shadow-sm border-0 text-center flex-fill" style="background:#2563eb; color:#fff; border-radius:10px; min-width:120px; max-width:220px; width:100%; cursor:pointer; margin-bottom:0;">
            <div class="card-body p-2">
              <i class="fas fa-layer-group fa-lg mb-1"></i>
              <h5 class="fw-bold mb-0"><%= current_user.subscriptions.count %></h5>
              <div style="font-size:13px;">Abonelik</div>
            </div>
          </div>
        <% end %>
        <%= link_to invoices_path, style: 'text-decoration:none;' do %>
          <div class="card shadow-sm border-0 text-center flex-fill" style="background:#f59e42; color:#fff; border-radius:10px; min-width:120px; max-width:220px; width:100%; cursor:pointer; margin-bottom:0;">
            <div class="card-body p-2">
              <i class="fas fa-file-invoice fa-lg mb-1"></i>
              <h5 class="fw-bold mb-0"><%= current_user.invoices.count %></h5>
              <div style="font-size:13px;">Fatura</div>
            </div>
          </div>
        <% end %>
      </div>
        <div class="fw-bold mb-3 text-center" style="font-size:18px;">Hoş geldin, <%= current_user.email %>!</div>
        <div class="d-flex justify-content-center mb-5" style="gap: 56px;">
          <div class="card shadow-sm border-0 p-4 d-flex flex-column align-items-center" style="border-radius:14px; width:420px; min-width:260px;">
            <h6 class="text-center mb-3">Faturalar</h6>
            <canvas id="invoicesBarH" width="360" height="220"></canvas>
          </div>
          <div class="card shadow-sm border-0 p-4 d-flex flex-column align-items-center" style="border-radius:14px; width:420px; min-width:260px;">
            <h6 class="text-center mb-3">Abonelikler</h6>
            <canvas id="subsPie" width="220" height="220"></canvas>
          </div>
        </div>
    <% else %>
      <div class="alert alert-info text-center">Lütfen giriş yapınız. Kişisel abonelik ve fatura bilgilerinizi görmek için üye girişi gereklidir.</div>
    <% end %>
    <!-- Fatura Durumları (Bar) ve (Pasta) kaldırıldı -->
    <% unless user_signed_in? %>
      <div class="mt-4 text-center">
        <%= link_to 'Giriş Yap', new_user_session_path, class: 'btn btn-primary me-2' %>
        <%= link_to 'Kayıt Ol', new_user_registration_path, class: 'btn btn-success' %>
      </div>
    <% end %>
    <% if user_signed_in? %>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Fatura verileri
        const paidCount = <%= current_user.invoices.where(status: 'paid').count %>;
        const unpaidCount = <%= current_user.invoices.where(status: 'unpaid').count %>;

        // Yatay Bar Chart (Faturalar)
        const barHCanvas = document.getElementById('invoicesBarH');
        if (barHCanvas) {
          const ctxBarH = barHCanvas.getContext('2d');
          new Chart(ctxBarH, {
            type: 'bar',
            data: {
              labels: ['Ödendi', 'Ödenmedi'],
              datasets: [{
                label: 'Fatura Sayısı',
                data: [paidCount, unpaidCount],
                backgroundColor: [
                  'rgba(34,197,94,1)',
                  'rgba(239,68,68,1)'
                ],
                borderRadius: 8
              }]
            },
            options: {
              indexAxis: 'y',
              plugins: { legend: { display: false } },
              scales: {
                x: { beginAtZero: true, ticks: { precision:0 } }
              }
            }
          });
        }

        // Abonelik verileri
        const activeCount = <%= current_user.subscriptions.where(status: 'active').count %>;
        const inactiveCount = <%= current_user.subscriptions.where(status: 'inactive').count %>;

        // Pie Chart (Abonelikler)
        const subsPieCanvas = document.getElementById('subsPie');
        if (subsPieCanvas) {
          const ctxSubsPie = subsPieCanvas.getContext('2d');
          new Chart(ctxSubsPie, {
            type: 'doughnut',
            data: {
              labels: ['Aktif', 'Pasif'],
              datasets: [{
                data: [activeCount, inactiveCount],
                backgroundColor: [
                  'rgba(34,197,94,1)',
                  'rgba(100,116,139,1)'
                ],
                borderWidth: 1
              }]
            },
            options: {
              cutout: '70%',
              plugins: {
                legend: { position: 'bottom' }
              }
            }
          });
        }
      });
    </script>
    <% end %>
  </main>
</div>
